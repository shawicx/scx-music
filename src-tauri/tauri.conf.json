{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scx-music",
  "version": "0.0.4",
  "identifier": "com.scx-music.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "scx-music",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://lrclib.net https://github.com https://github.com; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/shawicx/scx-music/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdGQjdFMTMzNEUwMTBCOTYKUldTV0N3Rk9NK0czZndybHJZYlNLS0YrYm9kZWRLbzFUMnlIa0tYRXpyc0cydnJYZG9KeHI3OTgK"
    }
  }
}
